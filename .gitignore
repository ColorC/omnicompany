# Agent-generated temp files (from BigCodeBench runtime)
BigCodeBench/
# bigcodebench / 竞赛目录污染防御
# 2026-04-21 修复: 原 test_*.py 和 solution*.py 是全局 ignore, 误杀了整个
# 项目的 tests/ 下 82 个单元测试。收缩到 bigcodebench*/ 子目录。
bigcodebench*/
bigcodebench*/solution*.py
bigcodebench*/solutions/
bigcodebench*/task/
bigcodebench*/task*/
bigcodebench*/task_*.py
bigcodebench*/test_*.py
C*workspacesolution.py
_commit_msg.txt
*.pyc

# Root-level anti-pollution (L1 2026-04-24 · CS-Agent 防垃圾网):
# agent bash 相对路径写入容易污染根 (Homestead.csv / MallGoods.lua 762KB / 1{for(i).
# 根级数据文件类永不该在此. 子目录 data/ src/ 不受影响.
/*.csv
/*.lua
/*.xlsm
/*.xlsx
/*.xls
/HomesteadBuilding.*
/HomesteadEntity.*
/HomesteadDecoFormula.*
/MallGoods.*
/MallSchedule.*
/Schedule.*
/1[{]*
/2
/test_cli.csv
/nul

# private domain — not for sharing
domains/local/

# Logs
logs/

# Local Claude/Codex machine state
.claude/settings.local.json
.claude/settings.json.pending-restart
.claude/settings.json.bak.*
.omni/core_activity_ts.json
.omni/sessions/_current.txt
.omni/sessions/*.json
.omni/tmp/
.omni/sandbox/
src/**/.omni/
*.tsbuildinfo
src/omnicompany/dashboard/extensions/*/out/
src/omnicompany/dashboard/extensions/**/*.vsix

# Domains (gitignore local only; gameplay_system is config)
domains/local/

# Autonomous runtime logs
data/autonomous/*.log
# gameplay_system learned scripts (generated per table, should not be committed)
data/gameplay_system/learned_scripts/
data/gameplay_system/logs/
token_data.json
*.token.json
scripts/extract_appsecret.py
scripts/refresh_token_test.py
scripts/try_tenant_access_token.py
scripts/extract_appsecret.py
scripts/feishu_auth_once.py
scripts/check_token.py

# personal_site: 站点 ssh/endpoint 含敏感信息, 走 yaml.example 模板入 git
config/personal_site/site.yaml

# guardian 运行态隔离区(卫士移入的污染, 留档但不跟踪)
.omni/quarantine/

# job_apply: 个人事实/自评/简历等运行态数据绝不进 git 代码目录(权威副本在 gitignored data/job_apply/)
scripts/job_apply/facts.json
scripts/job_apply/self_eval.md
scripts/job_apply/*.local.*
