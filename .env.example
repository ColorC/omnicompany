# omnicompany 环境变量样例 — 复制为 .env 并按本机填值。
# 本文件只列键名与说明, 不含任何密钥/真实工号/绝对路径。
#
# 加载: omni CLI 启动时 dotenv 自动读取仓根 .env。

# ── LLM / API keys ──
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
THE_COMPANY_API_KEY=
FIGMA_TOKEN=
TAVILY_API_KEY=
SERPER_API_KEY=

# ── 仓根 (可选) ──
# 不设则由 pyproject.toml 向上推导; dashboard/ccdaemon 注入时可显式指定。
# OMNI_WORKSPACE_ROOT=/abs/path/to/omnicompany

# ── ServiceBus 写入/cwd 工作区边界 (可选) ──
# 默认 = 仓根的父目录 + 开发机兜底 (/scm, C:\Users) + Unix tmp。
# 多盘/自定义工作区时用 os.pathsep 分隔覆盖 (Windows 用 ';')。
# OMNI_ALLOWED_WORKSPACE_PREFIXES=/workspace;/scm;C:\Users

# ── scm (gameplay_system 域) ──
# scm 客户端工作区根。各域 Client/Excel/Binary 子路径由此派生。
scm_ROOT=
# scm 客户端名 (项目代号)。兼容历史 EXPLORE_scm_CLIENT。
scm_CLIENT=
# gameplay_system-auto-config-sdk 绝对路径 (框架→SDK 唯一定位入口)。
gameplay_system_SDK_DIR=

# ── 简历资料库 (services/_governance/resume_steward) ──
# scm 作者工号 (身份, 无默认, 不进代码)。
RESUME_scm_USER=
# 原始 WorkUnit 落盘目录 (公司 IP 不进可发布仓)。
RESUME_STAGING_ROOT=
# git 仓发现的扫描根。
RESUME_GIT_SCAN_ROOT=

# ── 知识库 / 发布 / 研究 ──
# gameplay_system 知识库仓根 (独立外部仓)。
gameplay_system_KB_ROOT=
# 发布管线collaboration_platform语料目录 (仓外, 带日期, 易失效, 必须外注)。
PUBLISH_WIKI_CORPUS_ROOT=
# research 域参考项目扫描根。
OMNI_REFS_ROOT=
