# omnicompany — environment variables (example)
# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# ── LLM (optional) ───────────────────────────────────────────────
# Only needed for commands that call an LLM. Leave empty otherwise.
THE_COMPANY_API_KEY=

# ── Paths (optional) ─────────────────────────────────────────────
# Override the runtime data directory. Defaults to a dir resolved from the
# install location; set this to relocate generated state.
# OMNICOMPANY_DB_DIR=

# Override the workspace root the tools operate on. Defaults to the current
# working directory's repo.
# OMNI_WORKSPACE_ROOT=

# ── Bootstrap / CI (optional) ────────────────────────────────────
# Skip the Guardian startup self-check (used in CI / first-run bootstrap).
# OMNICOMPANY_SKIP_GUARDIAN_PRECHECK=1
